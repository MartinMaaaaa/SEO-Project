# ============================================================
# Private by default
# ============================================================

# Environment, API keys, OAuth tokens, service accounts, local secrets
.env
.env.*
*.secret
*.secrets
client_secret*.json
credentials*.json
token*.json
service-account*.json
*.pem
*.key
*.p12
*.crt

# API configuration and private account setup files
config/
*.local.json
*.local.yaml
*.local.yml

